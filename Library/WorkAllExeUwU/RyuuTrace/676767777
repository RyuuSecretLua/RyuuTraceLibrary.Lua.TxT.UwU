		function tabObj:AddDropdownToggle(label,options,default,callback)
			local ITEM_H=30
			local states={}
			for _,o in ipairs(options) do states[o]=(default and table.find(default,o)~=nil) end
			local bg=Instance.new("Frame") bg.Size=UDim2.new(1,0,0,54) bg.BackgroundTransparency=1 bg.ZIndex=4 bg.ClipsDescendants=false bg.Parent=page
			local lbl=Instance.new("TextLabel") lbl.Size=UDim2.new(1,0,0,18) lbl.BackgroundTransparency=1 lbl.Text=label lbl.Font=Enum.Font.Code lbl.TextSize=11 lbl.TextColor3=C.textDim lbl.TextXAlignment=Enum.TextXAlignment.Left lbl.ZIndex=5 lbl.Parent=bg
			local header=Instance.new("TextButton") header.Size=UDim2.new(1,0,0,30) header.Position=UDim2.new(0,0,0,20) header.BackgroundColor3=C.dropBg header.BorderSizePixel=0 header.Text="" header.AutoButtonColor=false header.ZIndex=5 header.Parent=bg Cor(header,8) Str(header,C.accent2,1.5)
			local selLbl=Instance.new("TextLabel") selLbl.Size=UDim2.new(1,-30,1,0) selLbl.Position=UDim2.new(0,10,0,0) selLbl.BackgroundTransparency=1 selLbl.Font=Enum.Font.Code selLbl.TextSize=12 selLbl.TextColor3=C.textMain selLbl.TextXAlignment=Enum.TextXAlignment.Left selLbl.ZIndex=6 selLbl.Parent=header
			local arrow=Instance.new("TextLabel") arrow.Size=UDim2.new(0,24,1,0) arrow.Position=UDim2.new(1,-26,0,0) arrow.BackgroundTransparency=1 arrow.Text="v" arrow.Font=Enum.Font.Code arrow.TextSize=11 arrow.TextColor3=C.textDim arrow.ZIndex=6 arrow.Parent=header
			local function updateHeader()
				local on={} for o,s in pairs(states) do if s then table.insert(on,o) end end
				selLbl.Text=#on>0 and table.concat(on,", ") or "None"
			end
			updateHeader()
			local dropList=Instance.new("Frame") dropList.Size=UDim2.new(1,0,0,#options*ITEM_H+4) dropList.Position=UDim2.new(0,0,0,52) dropList.BackgroundColor3=C.dropBg dropList.BorderSizePixel=0 dropList.ZIndex=10 dropList.Visible=false dropList.Parent=bg Cor(dropList,8) Str(dropList,C.accent2,1.5)
			local dl3=Instance.new("UIListLayout") dl3.SortOrder=Enum.SortOrder.LayoutOrder dl3.Padding=UDim.new(0,2) dl3.Parent=dropList
			local dp2=Instance.new("UIPadding") dp2.PaddingTop=UDim.new(0,2) dp2.PaddingBottom=UDim.new(0,2) dp2.PaddingLeft=UDim.new(0,2) dp2.PaddingRight=UDim.new(0,2) dp2.Parent=dropList
			local open=false
			local function setOpen(v)
				open=v dropList.Visible=v
				bg.Size=v and UDim2.new(1,0,0,54+#options*ITEM_H+8) or UDim2.new(1,0,0,54)
				arrow.Text=v and "^" or "v"
			end
			for i,opt in ipairs(options) do
				local row=Instance.new("Frame") row.Size=UDim2.new(1,0,0,ITEM_H) row.BackgroundColor3=C.dropItem row.BorderSizePixel=0 row.ZIndex=11 row.LayoutOrder=i row.Parent=dropList Cor(row,6)
				local rowLbl=Instance.new("TextLabel") rowLbl.Size=UDim2.new(1,-50,1,0) rowLbl.Position=UDim2.new(0,10,0,0) rowLbl.BackgroundTransparency=1 rowLbl.Text=opt rowLbl.Font=Enum.Font.Code rowLbl.TextSize=11 rowLbl.TextColor3=C.textMain rowLbl.TextXAlignment=Enum.TextXAlignment.Left rowLbl.ZIndex=12 rowLbl.Parent=row
				local rtrack=Instance.new("Frame") rtrack.Size=UDim2.new(0,34,0,17) rtrack.Position=UDim2.new(1,-42,0.5,-8.5) rtrack.BorderSizePixel=0 rtrack.ZIndex=12 rtrack.Parent=row Cor(rtrack,9)
				local rknob=Instance.new("Frame") rknob.Size=UDim2.new(0,12,0,12) rknob.BackgroundColor3=Color3.new(1,1,1) rknob.BorderSizePixel=0 rknob.ZIndex=13 rknob.Parent=rtrack Cor(rknob,6)
				local function refreshRow()
					if states[opt] then rtrack.BackgroundColor3=C.toggleOn rknob.Position=UDim2.new(0,19,0.5,-6)
					else rtrack.BackgroundColor3=C.toggleOff rknob.Position=UDim2.new(0,3,0.5,-6) end
				end
				refreshRow()
				local rhit=Instance.new("TextButton") rhit.Size=UDim2.new(1,0,1,0) rhit.BackgroundTransparency=1 rhit.Text="" rhit.ZIndex=14 rhit.Parent=row
				rhit.MouseEnter:Connect(function() Tw(row,{BackgroundColor3=C.dropHover},0.12):Play() end)
				rhit.MouseLeave:Connect(function() Tw(row,{BackgroundColor3=C.dropItem},0.12):Play() end)
				rhit.MouseButton1Click:Connect(function()
					states[opt]=not states[opt] refreshRow() updateHeader()
					if callback then callback(opt,states[opt],states) end
				end)
			end
			header.MouseButton1Click:Connect(function() setOpen(not open) end)
		end

		return tabObj
	end

